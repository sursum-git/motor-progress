  MAX-WIDTH 160
  COLUMN-LABEL "Campo Tb.01"
  ORDER 30

ADD FIELD "cod_cp_02" OF "meta_cp_relacs" AS character 
  FORMAT "x(80)"
  INITIAL ""
  LABEL "Campo Tb.02"
  POSITION 5
  MAX-WIDTH 160
  COLUMN-LABEL "Campo Tb.02"
  ORDER 40

ADD FIELD "dt_hr_registro" OF "meta_cp_relacs" AS datetime 
  FORMAT "99/99/9999 HH:MM:SS.SSS"
  INITIAL ?
