ADD INDEX "primario" ON "meta_tb_relacs" 
  AREA "indices"
  UNIQUE
  PRIMARY
  INDEX-FIELD "meta_tb_relac_id" ASCENDING 

ADD INDEX "ind_tb_01" ON "meta_tb_relacs" 
  AREA "indices"
