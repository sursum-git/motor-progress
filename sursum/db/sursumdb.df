ADD TABLE "meta_cp_relacs"
  AREA "dados"
  DUMP-NAME "meta_cp_relacs"

ADD FIELD "meta_cp_relac_id" OF "meta_cp_relacs" AS int64 
  FORMAT "->,>>>,>>9"
  INITIAL "0"
  LABEL "ID"
  POSITION 2
  MAX-WIDTH 8
  COLUMN-LABEL "ID"
  ORDER 10

